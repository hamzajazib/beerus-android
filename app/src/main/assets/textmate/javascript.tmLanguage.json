{
  "name": "JavaScript",
  "scopeName": "source.js",
  "fileTypes": ["js", "mjs", "cjs"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#template-strings" },
    { "include": "#regex" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#storage" },
    { "include": "#constants" },
    { "include": "#support" },
    { "include": "#functions" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.js",
          "match": "//.*$"
        },
        {
          "name": "comment.block.js",
          "begin": "/\\*",
          "end": "\\*/",
          "patterns": [
            {
              "name": "comment.block.documentation.js",
              "match": "(?<=\\*)\\s*@\\w+"
            }
          ]
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.js",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "include": "#string-escape" }
          ]
        },
        {
          "name": "string.quoted.single.js",
          "begin": "'",
          "end": "'",
          "patterns": [
            { "include": "#string-escape" }
          ]
        }
      ]
    },
    "string-escape": {
      "name": "constant.character.escape.js",
      "match": "\\\\(x[0-9A-Fa-f]{2}|u[0-9A-Fa-f]{4}|u\\{[0-9A-Fa-f]+\\}|[0-7]{1,3}|.)"
    },
    "template-strings": {
      "name": "string.template.js",
      "begin": "`",
      "end": "`",
      "patterns": [
        { "include": "#string-escape" },
        {
          "name": "meta.template.expression.js",
          "begin": "\\$\\{",
          "end": "\\}",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.template-expression.begin.js" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.template-expression.end.js" }
          },
          "patterns": [
            { "include": "$self" }
          ]
        }
      ]
    },
    "regex": {
      "name": "string.regexp.js",
      "begin": "(?<=[=(:,\\[!&|?{};]|^|return|=>)\\s*(/)",
      "end": "(/)[gimsuy]*",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.string.begin.js" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.definition.string.end.js" }
      },
      "patterns": [
        {
          "name": "constant.character.escape.js",
          "match": "\\\\."
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.js",
          "match": "\\b0[xX][0-9a-fA-F_]+n?\\b"
        },
        {
          "name": "constant.numeric.binary.js",
          "match": "\\b0[bB][01_]+n?\\b"
        },
        {
          "name": "constant.numeric.octal.js",
          "match": "\\b0[oO][0-7_]+n?\\b"
        },
        {
          "name": "constant.numeric.decimal.js",
          "match": "\\b\\d[\\d_]*(\\.\\d[\\d_]*)?([eE][+-]?\\d[\\d_]*)?n?\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.flow.js",
          "match": "\\b(break|case|catch|continue|debugger|default|do|else|finally|for|if|return|switch|throw|try|while|with|yield)\\b"
        },
        {
          "name": "keyword.control.conditional.js",
          "match": "\\b(if|else|switch|case|default)\\b"
        },
        {
          "name": "keyword.control.loop.js",
          "match": "\\b(for|while|do|in|of)\\b"
        },
        {
          "name": "keyword.control.trycatch.js",
          "match": "\\b(try|catch|finally|throw)\\b"
        },
        {
          "name": "keyword.operator.expression.js",
          "match": "\\b(delete|in|instanceof|new|typeof|void|await)\\b"
        }
      ]
    },
    "storage": {
      "patterns": [
        {
          "name": "storage.type.js",
          "match": "\\b(var|let|const|function|class|extends|static|get|set|async)\\b"
        },
        {
          "name": "storage.modifier.js",
          "match": "\\b(export|import|from|as|default)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.true.js",
          "match": "\\btrue\\b"
        },
        {
          "name": "constant.language.boolean.false.js",
          "match": "\\bfalse\\b"
        },
        {
          "name": "constant.language.null.js",
          "match": "\\bnull\\b"
        },
        {
          "name": "constant.language.undefined.js",
          "match": "\\bundefined\\b"
        },
        {
          "name": "constant.language.nan.js",
          "match": "\\bNaN\\b"
        },
        {
          "name": "constant.language.infinity.js",
          "match": "\\bInfinity\\b"
        }
      ]
    },
    "support": {
      "patterns": [
        {
          "name": "support.class.builtin.js",
          "match": "\\b(Array|Boolean|Date|Error|Function|JSON|Math|Number|Object|RegExp|String|Promise|Map|Set|WeakMap|WeakSet|Symbol|Proxy|Reflect|BigInt|ArrayBuffer|DataView|Int8Array|Uint8Array|Int16Array|Uint16Array|Int32Array|Uint32Array|Float32Array|Float64Array)\\b"
        },
        {
          "name": "support.function.js",
          "match": "\\b(eval|isFinite|isNaN|parseFloat|parseInt|decodeURI|decodeURIComponent|encodeURI|encodeURIComponent|setTimeout|setInterval|clearTimeout|clearInterval|setImmediate|clearImmediate|require)\\b"
        },
        {
          "name": "support.variable.js",
          "match": "\\b(console|window|document|global|globalThis|process|module|exports|__dirname|__filename)\\b"
        },
        {
          "name": "variable.language.this.js",
          "match": "\\bthis\\b"
        },
        {
          "name": "variable.language.super.js",
          "match": "\\bsuper\\b"
        },
        {
          "name": "variable.language.arguments.js",
          "match": "\\barguments\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "meta.function.js",
          "match": "\\b([a-zA-Z_$][a-zA-Z0-9_$]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.js" }
          }
        },
        {
          "name": "meta.function.arrow.js",
          "match": "\\b([a-zA-Z_$][a-zA-Z0-9_$]*)\\s*(?==\\s*(?:async\\s*)?(?:\\([^)]*\\)|[a-zA-Z_$][a-zA-Z0-9_$]*)\\s*=>)",
          "captures": {
            "1": { "name": "entity.name.function.js" }
          }
        },
        {
          "name": "meta.method-call.js",
          "match": "(?<=\\.)\\s*([a-zA-Z_$][a-zA-Z0-9_$]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.js" }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.js",
          "match": "=|\\+=|-=|\\*=|/=|%=|\\*\\*=|<<=|>>=|>>>=|&=|\\^=|\\|=|&&=|\\|\\|=|\\?\\?="
        },
        {
          "name": "keyword.operator.comparison.js",
          "match": "===|!==|==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.js",
          "match": "&&|\\|\\||!|\\?\\?"
        },
        {
          "name": "keyword.operator.arithmetic.js",
          "match": "\\+\\+|--|\\+|-|\\*\\*|\\*|/|%"
        },
        {
          "name": "keyword.operator.bitwise.js",
          "match": "&|\\||\\^|~|<<|>>>|>>"
        },
        {
          "name": "keyword.operator.ternary.js",
          "match": "\\?|:"
        },
        {
          "name": "keyword.operator.spread.js",
          "match": "\\.\\.\\."
        },
        {
          "name": "keyword.operator.arrow.js",
          "match": "=>"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.terminator.statement.js",
          "match": ";"
        },
        {
          "name": "punctuation.separator.comma.js",
          "match": ","
        },
        {
          "name": "punctuation.accessor.js",
          "match": "\\."
        },
        {
          "name": "punctuation.accessor.optional-chain.js",
          "match": "\\?\\."
        }
      ]
    }
  }
}
